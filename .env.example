# Variables d'environnement (pour le futur)
# Copier ce fichier en .env.local et remplir les valeurs réelles

# API Backend
VITE_API_URL=http://localhost:3000/api
VITE_API_KEY=your_api_key_here

# Service Exchange Rate
VITE_EXCHANGE_RATE_API=https://api.exchangerate-api.com/v4/latest/USD

# Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Blockchain Networks
VITE_STELLAR_NETWORK=public  # ou testnet
VITE_CELO_NETWORK=mainnet    # ou testnet

# Contact Email
VITE_CONTACT_EMAIL=contact@diaspora-connect.com

# Environnement
VITE_ENV=production  # ou development
